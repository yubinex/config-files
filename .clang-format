---
# Base style to start from
BasedOnStyle: LLVM

# --- Indentation & Access Modifiers ---
IndentWidth: 4
AccessModifierOffset: -4
NamespaceIndentation: All

# --- Pointer Alignment ---
PointerAlignment: Right

# --- Initialization Spacing ---
# This creates: Vector3 { a.x ... };
Cpp11BracedListStyle: false

# --- Column Alignment ---
AlignConsecutiveAssignments: AcrossEmptyLines
AlignConsecutiveDeclarations:
  Enabled: true
  AcrossEmptyLines: true
  AlignFunctionDeclarations: false
AlignTrailingComments: true

# --- Constructor Layout ---
BreakConstructorInitializers: BeforeComma
PackConstructorInitializers: BinPack
ConstructorInitializerIndentWidth: 4

# --- Control Statements & Functions (Force Multi-line) ---
# This prevents your operator+ from collapsing into one line
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

# --- Extra Cleanliness ---
BreakBeforeBraces: Attach
ColumnLimit: 100
MaxEmptyLinesToKeep: 1

# --- Header Management ---
SortIncludes: true
IncludeBlocks: Regroup

# Ensure modern C++ support
Standard: Latest
